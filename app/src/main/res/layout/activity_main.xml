<?xml version="1.0" encoding="utf-8"?>
<LinearLayout 
    xmlns:android="http://schemas.github.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#121212"> <!-- Koyu tema arka planı -->

    <!-- Başlık veya Durum Metni -->
    <TextView
        android:id="@+id/statusTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Injector Status: Ready"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"/>

    <!-- İşlem Seçenekleri İçin Ağırlıklı (Weight) Alan -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Loglarda geçen margin ve hizalama hataları düzeltilmiş buton -->
        <Button
            android:id="@+id/btnInject"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Inject"
            android:backgroundTint="#00E676"
            android:textColor="#000000"
            android:layout_marginBottom="12dp"
            android:layout_marginEnd="0dp"/>

        <Button
            android:id="@+id/btnSelectProcess"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select Process"
            android:backgroundTint="#29B6F6"
            android:textColor="#000000"
            android:layout_marginBottom="12dp"
            android:layout_marginEnd="0dp"/>

    </LinearLayout>

    <!-- Alt Kısımda Sabit Duracak Bilgi Metni -->
    <TextView
        android:id="@+id/versionTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="v2.0 - Build Successful"
        android:textColor="#757575"
        android:textSize="12sp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="4dp"/>

</LinearLayout>
